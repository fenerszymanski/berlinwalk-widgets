```js
await (async (page) => {
  const outDir = '/Users/yusufucuz/Documents/New project/berlinwalk-widgets/output/qa/berlin-u-bahn-fine';
  const url = 'http://127.0.0.1:8796/berlin-ticket-fine-step-planner/?qa=20260706g';
  const viewports = [
    { name: 'desktop', width: 1280, height: 1200 },
    { name: 'mobile-390', width: 390, height: 1100 },
  ];
  const errors = [];
  page.on('console', (msg) => {
    if (msg.type() === 'error') errors.push(msg.text());
  });
  page.on('pageerror', (error) => errors.push(error.message));

  const results = [];
  for (const viewport of viewports) {
    errors.length = 0;
    await page.setViewportSize({ width: viewport.width, height: viewport.height });
    await page.goto(url + '&viewport=' + viewport.name, { waitUntil: 'networkidle' });

    async function clickScenario(name) {
      await page.locator(`[data-scenario="${name}"]`).click();
      await page.waitForTimeout(80);
    }

    async function clickOperator(name) {
      await page.locator(`[data-operator="${name}"]`).click();
      await page.waitForTimeout(80);
    }

    async function text(selector) {
      return (await page.locator(selector).innerText()).replace(/\s+/g, ' ').trim();
    }

    await clickScenario('personal');
    await clickOperator('bvg');
    const personal = {
      title: await text('#result-title'),
      amount: await text('#result-amount'),
      label: await text('#result-amount-label'),
      warning: await text('#result-warning'),
    };

    await clickOperator('sbahn');
    const sbahnWarning = await text('#result-warning');

    await clickScenario('id');
    const idReceiptText = await text('.receipt');
    const id = {
      title: await text('#result-title'),
      amount: await text('#result-amount'),
      label: await text('#result-amount-label'),
    };

    await clickScenario('zone');
    const zone = {
      title: await text('#result-title'),
      warning: await text('#result-warning'),
    };

    await clickScenario('digital');
    const digital = {
      title: await text('#result-title'),
      warning: await text('#result-warning'),
    };

    const layout = await page.evaluate(() => ({
      innerWidth,
      scrollWidth: document.documentElement.scrollWidth,
      clientWidth: document.documentElement.clientWidth,
      overflowX: Math.max(0, document.documentElement.scrollWidth - document.documentElement.clientWidth),
      bodyTextHasOldCash: document.body.innerText.includes('do not demand cash without receipt') || document.body.innerText.includes('proper receipt handling'),
      bodyTextHasIdentityFee: document.body.innerText.includes('identity-check fee') || document.body.innerText.includes('extra ID fee'),
    }));

    await page.screenshot({ path: `${outDir}/widget-branch-qa-${viewport.name}-20260706g.png`, fullPage: true });

    const assertions = {
      personalBvgEur7: personal.amount === 'EUR 7',
      sbahnNoteExact: sbahnWarning.includes('S-Bahn says its inspectors never demand cash; on-the-spot payment is by card only. A cash demand is a red flag.'),
      idNoFeeClaim: !idReceiptText.includes('identity-check fee') && !idReceiptText.includes('extra ID fee') && id.label.toLowerCase() === 'standard amount',
      idPoliceText: idReceiptText.includes('inspectors can involve the police to confirm your identity'),
      zoneBranch: zone.title.includes('Fix the zone'),
      digitalBranch: digital.title.includes('Assume late activation'),
      consoleZero: errors.length === 0,
      overflowZero: layout.overflowX === 0,
      noOldPhrases: !layout.bodyTextHasOldCash && !layout.bodyTextHasIdentityFee,
    };
    results.push({
      viewport,
      ok: Object.values(assertions).every(Boolean),
      assertions,
      personal,
      sbahnWarning,
      id,
      zone,
      digital,
      layout,
      consoleErrors: [...errors],
    });
  }

  return {
    checkedAt: new Date().toISOString(),
    url,
    ok: results.every((result) => result.ok),
    results,
  };
}
)(page);
